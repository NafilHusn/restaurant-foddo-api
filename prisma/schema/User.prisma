model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  phone          String?
  name           String?
  country        String?
  active         Boolean   @default(true)
  profilePicture String?
  lastLoginAt    DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())

  Role             Role[]
  userSessions     UserSession[]
  checkedOutOrders Order[]       @relation("CheckedOutOrders")
  sharedItems      CartItem[]
  cart             Cart[]
  cartShares       CartShare[]
  addedItems       OrderItem[]   @relation("AddedItems")

  @@index([email])
  @@index([phone])
}
